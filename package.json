{
  "name": "@vaultfire/xmtp",
  "version": "1.0.0",
  "description": "Trust-gated XMTP agent messaging with on-chain Vaultfire bond verification. Encrypted agent-to-agent communication on Base, Avalanche, Arbitrum, and Polygon.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/xmtp-browser.mjs",
      "require": "./dist/xmtp-browser.js",
      "types": "./dist/xmtp-browser.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "xmtp",
    "vaultfire",
    "agent",
    "messaging",
    "trust",
    "blockchain",
    "base",
    "avalanche",
    "x402",
    "bonds",
    "encrypted",
    "web3",
    "AI",
    "accountability",
    "arbitrum",
    "polygon"
  ],
  "author": "Vaultfire Protocol <theloopbreaker.com>",
  "license": "MIT",
  "homepage": "https://theloopbreaker.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ghostkey316/vaultfire-xmtp.git"
  },
  "bugs": {
    "url": "https://github.com/Ghostkey316/vaultfire-xmtp/issues"
  },
  "peerDependencies": {
    "@xmtp/agent-sdk": ">=2.2.0",
    "ethers": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/elliptic": "^6.4.18",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@xmtp/agent-sdk": "^2.2.0",
    "ethers": "^6.16.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  },
  "optionalDependencies": {
    "@xmtp/xmtp-js": "^11.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
